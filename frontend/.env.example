# =============================================================================
# Configuration du frontend Balance (Vite)
# Copiez ce fichier en `.env` puis adaptez les valeurs.
# Les variables exposées au navigateur DOIVENT commencer par VITE_.
# =============================================================================

# URL de base de l'API REST du backend (suffixe /api inclus)
VITE_API_URL=http://localhost:3006/api

# URL du WebSocket temps réel du backend
# Doit pointer vers le MÊME port que le backend (3006 par défaut).
VITE_WS_URL=ws://localhost:3006/ws
