# =============================================================================
# Configuration du backend Balance
# Copiez ce fichier en `.env` puis adaptez les valeurs.
# =============================================================================

# Environnement : "development" (PGlite local) ou "production" (PostgreSQL)
NODE_ENV=development

# Port et hôte d'écoute du serveur Fastify.
# Sur AlwaysData, laissez vides : le serveur écoute sur ALWAYSDATA_HTTPD_IP/PORT.
PORT=3006
HOST=0.0.0.0

# --- Production uniquement ---
# Chaîne de connexion PostgreSQL (ex. AlwaysData). Requise si NODE_ENV=production.
DATABASE_URL=postgres://utilisateur:motdepasse@hote:5432/balance

# Secret de signature des jetons JWT.
# OBLIGATOIRE en production (le serveur refuse de démarrer sans).
# Générez une valeur forte, ex. : openssl rand -base64 48
JWT_SECRET=remplacez-moi-par-un-secret-aleatoire-long

# Origine autorisée pour le CORS (URL du frontend).
# INUTILE en mode « 1 seul site » (le backend sert le frontend -> même origine).
# À définir UNIQUEMENT si le frontend est hébergé sur une autre origine.
# Ex. : https://balance.mondomaine.fr
# CORS_ORIGIN=https://balance.mondomaine.fr

# Optionnel : chemin du build frontend à servir (défaut : ../frontend/dist
# relatif au backend). Utile si le frontend est buildé ailleurs.
# FRONTEND_DIST=/chemin/vers/frontend/dist
